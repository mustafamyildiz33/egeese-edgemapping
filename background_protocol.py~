import time
import json
from urllib import request, error

import egess_api # To access common EGESS functions


def _post_json(url: str, payload: dict, timeout: float = 0.6):
    data = json.dumps(payload).encode("utf-8")
    req = request.Request(
        url,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with request.urlopen(req, timeout=timeout) as resp:
        raw = resp.read().decode("utf-8")
        return json.loads(raw)


def _pull_state(config_json, target_port: int):
    payload = {"op": "pull", "data": {}, "metadata": {}}
    host = config_json.get("base_host", "127.0.0.1")
    url = "http://{}:{}/".format(host, str(target_port))
    try:
        res = _post_json(url, payload)
        if isinstance(res, dict) and res.get("op") == "receipt":
            data = res.get("data", {})
            if isinstance(data, dict) and "node_state" in data:
                return data["node_state"]
    except Exception:
        return None
    return None


def _port_to_rc(config_json, port: int):
    base_port = int(config_json.get("base_port", 9000))
    cols = int(config_json.get("grid_cols", 8))
    idx = port - base_port
    r = idx // cols
    c = idx % cols
    return r, c


def _rc_to_port(config_json, r: int, c: int):
    base_port = int(config_json.get("base_port", 9000))
    cols = int(config_json.get("grid_cols", 8))
    return base_port + (r * cols + c)


def _neighbors_4(config_json, this_port: int, number_of_nodes: int):
    cols = int(config_json.get("grid_cols", 8))
    rows = int(config_json.get("grid_rows", max(1, (number_of_nodes + cols - 1) // cols)))
    r, c = _port_to_rc(config_json, this_port)
    out = []
    cand = [(r - 1, c), (r + 1, c), (r, c - 1), (r, c + 1)]
    for rr, cc in cand:
        if 0 <= rr < rows and 0 <= cc < cols:
            p = _rc_to_port(config_json, rr, cc)
            if int(config_json.get("base_port", 9000)) <= p < int(config_json.get("base_port", 9000)) + number_of_nodes:
                out.append(p)
    return out


def _is_sentinel(config_json, this_port: int, number_of_nodes: int):
    base_port = int(config_json.get("base_port", 9000))
    cols = int(config_json.get("grid_cols", 8))
    rows = int(config_json.get("grid_rows", max(1, (number_of_nodes + cols - 1) // cols)))
    idx = this_port - base_port
    r = idx // cols
    c = idx % cols
    if r == 0 or c == 0 or r == (rows - 1) or c == (cols - 1):
        return True
    stride = int(config_json.get("sentinel_stride", 0))
    if stride and stride > 0:
        return (idx % stride) == 0
    return False


def _hazard_state(config_json, this_port: int, number_of_nodes: int):
    base_port = int(config_json.get("base_port", 9000))
    cols = int(config_json.get("grid_cols", 8))
    rows = int(config_json.get("grid_rows", max(1, (number_of_nodes + cols - 1) // cols)))
    idx = this_port - base_port
    r = idx // cols
    c = idx % cols

    haz_mode = str(config_json.get("hazard_mode", "center_square"))
    if haz_mode == "none":
        return "NORMAL"

    if haz_mode == "center_square":
        k = int(config_json.get("hazard_square_radius", 1))
        cr = rows // 2
        cc = cols // 2
        if abs(r - cr) <= k and abs(c - cc) <= k:
            return "HAZARD"
        return "NORMAL"

    return "NORMAL"


def background_protocol(config_json, node_state, state_lock, this_port, number_of_nodes, push_queue):
    """
    Background protocol function. It is called with a certain frequency/period specified
    in the all-nodes configuration.

    Args:
        config_json (dict[str, Any]): JSON object with all-nodes configuration.
        node_state (dict[str, Any]): The state of this current node.
        state_lock (threading.Lock): The lock object for thread-safety of the state.
        this_port (int): The port this node listens.
        number_of_nodes (int): The total number of nodes in the network (if known).
        push_queue (queue.Queue): The queue for messages to be pushed to other node(s).
    """
    now = time.time()

    role = "sentinel" if _is_sentinel(config_json, this_port, number_of_nodes) else "normal"
    sensed = _hazard_state(config_json, this_port, number_of_nodes)

    neighbors = _neighbors_4(config_json, this_port, number_of_nodes)

    neighbor_states = {}
    missing = []
    for p in neighbors:
        st = _pull_state(config_json, p)
        if st is None:
            missing.append(p)
        else:
            neighbor_states[p] = st.get("sensor_state", "UNKNOWN")

    boundary_edges = []
    my_state = sensed

    for p, pst in neighbor_states.items():
        if pst != "UNKNOWN" and pst != my_state:
            boundary_edges.append({"a": this_port, "b": p, "reason": "state_mismatch", "tick": int(now)})

    missing_threshold = int(config_json.get("missing_streak_threshold", 3))

    state_lock.acquire()
    node_state["background_hits"] = node_state["background_hits"] + 1
    node_state["role"] = role
    node_state["sensor_state"] = my_state

    if "missing_streak" not in node_state or not isinstance(node_state["missing_streak"], dict):
        node_state["missing_streak"] = {}
    for p in neighbors:
        key = str(p)
        if key not in node_state["missing_streak"]:
            node_state["missing_streak"][key] = 0
    for p in missing:
        key = str(p)
        node_state["missing_streak"][key] = int(node_state["missing_streak"].get(key, 0)) + 1
    for p in neighbors:
        if p not in missing:
            key = str(p)
            node_state["missing_streak"][key] = 0

    emergency = False
    for p in missing:
        if int(node_state["missing_streak"].get(str(p), 0)) >= missing_threshold:
            emergency = True
            break
    node_state["emergency_mode"] = emergency

    node_state["boundary_edges"] = boundary_edges

    egess_api.log_current_node_state(this_port, node_state)
    egess_api.write_state_change_data_point(this_port, node_state, "background_hits")
    egess_api.write_state_change_data_point(this_port, node_state, "role")
    egess_api.write_state_change_data_point(this_port, node_state, "sensor_state")
    egess_api.write_state_change_data_point(this_port, node_state, "emergency_mode")
    egess_api.write_state_change_data_point(this_port, node_state, "boundary_edges")
    state_lock.release()

    hb_period = float(config_json.get("heartbeat_period", 2.0))
    do_hb = (int(now) % max(1, int(hb_period))) == 0
    if do_hb:
        hb = {
            "op": "push",
            "data": {"type": "heartbeat"},
            "metadata": {"relay": 0, "forward_count": 0, "origin": this_port}
        }
        push_queue.put(hb)

    if emergency:
        for p in missing:
            rep = {
                "op": "push",
                "data": {"type": "missing_report", "missing_port": p},
                "metadata": {"relay": 0, "forward_count": 0, "origin": this_port}
            }
            push_queue.put(rep)
